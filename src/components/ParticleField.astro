<canvas class="particle-field" data-particles aria-hidden="true"></canvas>
<div class="scan-grid" aria-hidden="true"></div>

<script>
	const canvas = document.querySelector('[data-particles]');
	const ctx = canvas instanceof HTMLCanvasElement ? canvas.getContext('2d') : null;
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (canvas instanceof HTMLCanvasElement && ctx) {
		const palette = ['0, 245, 212', '255, 45, 149', '255, 207, 74', '156, 255, 106'];
		const maxCanvasPixels = 920000;
		let particles = [];
		let animationId = 0;
		let lastFrame = 0;

		const resize = () => {
			const width = window.innerWidth;
			const height = window.innerHeight;
			const pixelScale = Math.min(1, Math.sqrt(maxCanvasPixels / Math.max(width * height, 1)));
			canvas.width = Math.max(1, Math.floor(width * pixelScale));
			canvas.height = Math.max(1, Math.floor(height * pixelScale));
			canvas.style.width = `${width}px`;
			canvas.style.height = `${height}px`;
			ctx.setTransform(pixelScale, 0, 0, pixelScale, 0, 0);

			const count = reducedMotion
				? 24
				: Math.min(46, Math.max(24, Math.floor((width * height) / 52000)));

			particles = Array.from({ length: count }, (_, index) => ({
				x: Math.random() * width,
				y: Math.random() * height,
				vx: (Math.random() - 0.5) * 0.34,
				vy: (Math.random() - 0.5) * 0.34,
				r: 0.9 + Math.random() * 1.8,
				tone: palette[index % palette.length],
			}));
		};

		const draw = () => {
			const width = window.innerWidth;
			const height = window.innerHeight;
			const linkDistance = 104;
			const linkDistanceSq = linkDistance * linkDistance;
			ctx.clearRect(0, 0, width, height);
			ctx.globalCompositeOperation = 'lighter';
			ctx.shadowBlur = 0;

			for (let index = 0; index < particles.length; index += 1) {
				const particle = particles[index];

				if (!reducedMotion) {
					particle.x += particle.vx;
					particle.y += particle.vy;

					if (particle.x < -20) particle.x = width + 20;
					if (particle.x > width + 20) particle.x = -20;
					if (particle.y < -20) particle.y = height + 20;
					if (particle.y > height + 20) particle.y = -20;
				}

				ctx.beginPath();
				ctx.fillStyle = `rgba(${particle.tone}, 0.72)`;
				ctx.arc(particle.x, particle.y, particle.r, 0, Math.PI * 2);
				ctx.fill();

				for (let nextIndex = index + 1; nextIndex < particles.length; nextIndex += 1) {
					const next = particles[nextIndex];
					const dx = particle.x - next.x;
					const dy = particle.y - next.y;
					const distanceSq = dx * dx + dy * dy;

					if (distanceSq < linkDistanceSq) {
						const alpha = (1 - distanceSq / linkDistanceSq) * 0.11;
						ctx.beginPath();
						ctx.strokeStyle = `rgba(${particle.tone}, ${alpha})`;
						ctx.lineWidth = 1;
						ctx.moveTo(particle.x, particle.y);
						ctx.lineTo(next.x, next.y);
						ctx.stroke();
					}
				}
			}

		};

		const tick = (time) => {
			if (document.hidden) {
				animationId = 0;
				return;
			}

			if (time - lastFrame > 66) {
				lastFrame = time;
				draw();
			}

			if (!reducedMotion) {
				animationId = requestAnimationFrame(tick);
			}
		};

		const start = () => {
			if (!reducedMotion && animationId === 0 && !document.hidden) {
				animationId = requestAnimationFrame(tick);
			}
		};

		resize();
		if (reducedMotion) {
			draw();
		} else {
			start();
		}
		window.addEventListener('resize', resize, { passive: true });
		document.addEventListener('visibilitychange', () => {
			if (document.hidden) {
				cancelAnimationFrame(animationId);
				animationId = 0;
				return;
			}

			draw();
			start();
		});
	}
</script>

<style>
	.particle-field,
	.scan-grid {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.particle-field {
		z-index: 2;
		opacity: 0.76;
	}

	.scan-grid {
		z-index: 3;
		background:
			repeating-linear-gradient(
				90deg,
				rgba(0, 245, 212, 0.08) 0 1px,
				transparent 1px 74px
			),
			repeating-linear-gradient(
				0deg,
				rgba(255, 45, 149, 0.06) 0 1px,
				transparent 1px 74px
			),
			repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.05) 0 1px, transparent 1px 5px);
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.92), rgba(0, 0, 0, 0.2));
	}

	.scan-grid::after {
		position: absolute;
		inset: 0;
		content: '';
		background: linear-gradient(
			180deg,
			transparent 0%,
			rgba(0, 245, 212, 0.12) 48%,
			transparent 52%
		);
		animation: scan 7s linear infinite;
	}

	@keyframes scan {
		from {
			transform: translateY(-100%);
		}

		to {
			transform: translateY(100%);
		}
	}
</style>
