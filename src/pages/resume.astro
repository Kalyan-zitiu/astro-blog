---
import ParticleField from '../components/ParticleField.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="简历 | Kalyan" description="Kalyan 的简历入口页。">
	<ParticleField />
	<main class="resume-shell">
		<a class="back-link" href="/#top">返回首页</a>
		<section class="resume-panel" aria-labelledby="resume-title">
			<p class="system-label">Resume uplink</p>
			<h1 id="resume-title">Kalyan</h1>
			<p class="lead">这里可以放你的个人简介、技能栈、项目经历和联系方式。当前页面先作为简历入口，避免首页链接指向空地址。</p>

			<div class="resume-grid">
				<div>
					<strong>方向</strong>
					<p>前端工程 / 内容系统 / 自动化工作流</p>
				</div>
				<div>
					<strong>技能</strong>
					<p>Astro, TypeScript, UI Engineering, Markdown Publishing</p>
				</div>
				<div>
					<strong>联系</strong>
					<p><a href="mailto:hello@kalyan.dev">hello@kalyan.dev</a></p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.resume-shell {
		width: min(900px, calc(100% - 32px));
		margin: 0 auto;
		padding: 48px 0 90px;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 24px;
		color: var(--cyan);
		font-size: 14px;
		font-weight: 800;
		text-decoration: none;
		text-transform: uppercase;
	}

	.resume-panel {
		position: relative;
		padding: 34px;
		border: 1px solid rgba(0, 245, 212, 0.34);
		border-radius: 8px;
		background: linear-gradient(145deg, rgba(10, 16, 24, 0.94), rgba(18, 24, 35, 0.84));
		box-shadow:
			12px 12px 0 rgba(0, 245, 212, 0.08),
			22px 22px 0 rgba(255, 45, 149, 0.06),
			0 34px 70px rgba(0, 0, 0, 0.42);
	}

	.resume-panel::before {
		position: absolute;
		inset: 8px -12px -12px 8px;
		z-index: -1;
		border-radius: 8px;
		content: '';
		background: linear-gradient(135deg, rgba(0, 245, 212, 0.16), rgba(255, 45, 149, 0.16));
	}

	.system-label {
		margin: 0 0 16px;
		color: var(--green);
		font-size: 13px;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: 64px;
		line-height: 1;
	}

	.lead {
		max-width: 720px;
		margin: 20px 0 0;
		color: var(--muted);
		font-size: 18px;
		line-height: 1.8;
	}

	.resume-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
		margin-top: 30px;
	}

	.resume-grid div {
		min-height: 130px;
		padding: 18px;
		border: 1px solid rgba(146, 246, 255, 0.22);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.04);
		box-shadow:
			7px 7px 0 rgba(0, 245, 212, 0.07),
			13px 13px 0 rgba(255, 45, 149, 0.05);
	}

	.resume-grid strong {
		display: block;
		margin-bottom: 10px;
		color: #ffffff;
		font-size: 18px;
	}

	.resume-grid p {
		margin: 0;
		color: var(--muted);
		line-height: 1.7;
	}

	.resume-grid a {
		color: var(--cyan);
	}

	@media (max-width: 760px) {
		.resume-panel {
			padding: 24px 18px;
		}

		h1 {
			font-size: 46px;
		}

		.resume-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
