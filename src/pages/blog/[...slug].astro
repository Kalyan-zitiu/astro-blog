---
import { getCollection, render } from 'astro:content';
import ParticleField from '../../components/ParticleField.astro';
import Layout from '../../layouts/Layout.astro';

const categoryLabel = {
	life: '生活',
	tech: '技术',
	work: '工作',
};

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => data.draft !== true);

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formatDate = (date: Date) =>
	new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
	}).format(date);
---

<Layout title={`${post.data.title} | Kalyan`} description={post.data.description}>
	<ParticleField />
	<main class="article-shell">
		<a class="back-link" href="/#blog">返回文章分类</a>
		<article class={`article-page accent-${post.data.accent}`}>
			<header class="article-header">
				<p class="system-label">{categoryLabel[post.data.category]} / {formatDate(post.data.pubDate)}</p>
				<h1>{post.data.title}</h1>
				<p>{post.data.description}</p>
				<div class="tag-row">
					{post.data.tags.map((tag) => (
						<span>{tag}</span>
					))}
				</div>
			</header>
			<div class="article-body">
				<Content />
			</div>
		</article>
	</main>
</Layout>

<style>
	.article-shell {
		width: min(1180px, calc(100% - 40px));
		margin: 0 auto;
		padding: 46px 0 96px;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		margin-bottom: 24px;
		color: var(--cyan);
		font-size: 14px;
		font-weight: 800;
		text-decoration: none;
		text-transform: uppercase;
	}

	.back-link:hover,
	.back-link:focus-visible {
		color: var(--amber);
	}

	.article-page {
		position: relative;
		min-height: calc(100vh - 150px);
	}

	.article-header {
		padding: 44px 0 38px;
		border-bottom: 1px solid color-mix(in srgb, var(--accent, var(--cyan)) 34%, transparent);
		background:
			linear-gradient(90deg, rgba(0, 245, 212, 0.09), transparent 38%),
			linear-gradient(135deg, rgba(255, 45, 149, 0.08), transparent 42%);
	}

	.system-label {
		margin: 0 0 16px;
		color: var(--amber);
		font-size: 13px;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.article-header h1 {
		margin: 0;
		max-width: 980px;
		font-size: clamp(42px, 6vw, 86px);
		line-height: 1.08;
	}

	.article-header p:not(.system-label) {
		max-width: 860px;
		margin: 22px 0 0;
		color: var(--muted);
		font-size: 21px;
		line-height: 1.8;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 20px;
	}

	.tag-row span {
		padding: 6px 9px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.05);
		color: #d7e7f2;
		font-size: 12px;
	}

	.article-body {
		width: min(920px, 100%);
		padding-top: 46px;
		color: #dce9f4;
		font-size: 20px;
		line-height: 2;
	}

	:global(.article-body h2) {
		margin: 48px 0 16px;
		color: #ffffff;
		font-size: 34px;
		line-height: 1.25;
	}

	:global(.article-body p) {
		margin: 0 0 24px;
	}

	:global(.article-body code) {
		padding: 2px 6px;
		border: 1px solid rgba(0, 245, 212, 0.28);
		border-radius: 6px;
		background: rgba(0, 245, 212, 0.08);
		color: var(--green);
	}

	.accent-cyan {
		--accent: var(--cyan);
	}

	.accent-magenta {
		--accent: var(--magenta);
	}

	.accent-amber {
		--accent: var(--amber);
	}

	.accent-green {
		--accent: var(--green);
	}

	@media (max-width: 680px) {
		.article-shell {
			width: min(100% - 24px, 1180px);
			padding-top: 28px;
		}

		.article-header h1 {
			font-size: 34px;
		}

		.article-body {
			font-size: 16px;
			line-height: 1.9;
		}
	}
</style>
