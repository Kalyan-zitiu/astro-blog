---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Kalyan | Cyber Blog',
	description = 'Kalyan 的个人博客入口，收纳生活、技术与工作记录。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#05070d" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #05070d;
		--panel: rgba(10, 16, 24, 0.78);
		--panel-strong: rgba(15, 24, 34, 0.92);
		--text: #edf7ff;
		--muted: #9db2c4;
		--line: rgba(128, 245, 255, 0.22);
		--cyan: #00f5d4;
		--magenta: #ff2d95;
		--amber: #ffcf4a;
		--green: #9cff6a;
		--violet: #a78bfa;
		--shadow-cyan: rgba(0, 245, 212, 0.18);
		--shadow-magenta: rgba(255, 45, 149, 0.18);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-width: 320px;
		min-height: 100%;
		background: var(--bg);
		color: var(--text);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		scroll-behavior: smooth;
	}

	body {
		min-height: 100vh;
		overflow-x: hidden;
		text-rendering: geometricPrecision;
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -7;
		content: '';
		background:
			linear-gradient(115deg, rgba(0, 245, 212, 0.08), transparent 34%),
			linear-gradient(245deg, rgba(255, 45, 149, 0.08), transparent 36%);
	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	button {
		color: inherit;
	}

	a {
		color: inherit;
	}

	::selection {
		background: rgba(0, 245, 212, 0.34);
		color: #ffffff;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}

		*,
		*::before,
		*::after {
			animation-duration: 0.001ms !important;
			animation-iteration-count: 1 !important;
			scroll-behavior: auto !important;
			transition-duration: 0.001ms !important;
		}
	}
</style>
